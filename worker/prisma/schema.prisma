generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String          @unique
  password_hash String
  display_name  String?
  timezone      String          @default("UTC")
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  buckets       Bucket[]
  notes         Note[]
  interactions  AiInteraction[]

  @@map("users")
}

model Bucket {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String          @db.Uuid
  name         String
  fields       Json            @default("[]")
  created_at   DateTime        @default(now()) @db.Timestamptz(6)
  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  notes        Note[]
  interactions AiInteraction[]

  @@index([user_id], map: "idx_buckets_user_id")
  @@map("buckets")
}

model Note {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @db.Uuid
  bucket_id        String   @db.Uuid
  original_text    String
  structured_json  Json?
  archived         Boolean  @default(false)
  category         String?
  audio_url        String?
  archive_url      String?
  duration_seconds Float?
  waveform_json    Json?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bucket           Bucket   @relation(fields: [bucket_id], references: [id], onDelete: Cascade)

  @@index([user_id, bucket_id, created_at(sort: Desc)], map: "idx_notes_user_bucket_created_at")
  @@index([user_id, bucket_id, archived, created_at(sort: Desc)], map: "idx_notes_user_bucket_archived_created_at")
  @@map("notes")
}

model AiInteraction {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  bucket_id         String   @db.Uuid
  input_text        String
  llm_output        Json?
  corrected_output  Json?
  corrected_by_user Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bucket            Bucket   @relation(fields: [bucket_id], references: [id], onDelete: Cascade)

  @@index([user_id, bucket_id, created_at(sort: Desc)], map: "idx_ai_interactions_user_bucket_created_at")
  @@map("ai_interactions")
}
