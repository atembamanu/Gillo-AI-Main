# =============================================================================
# Gillo — single root .env for Docker Compose (copy to .env and fill secrets)
# Never commit .env — use Dokploy / CI secret injection in production.
# =============================================================================

# --- Domains (production) ---
# Public API origin (HTTPS, no trailing slash). Required when SPA is on gilloai.com and API on api.gilloai.com
PUBLIC_API_URL=https://api.gilloai.com
# Comma-separated browser origins allowed to call the API (CORS)
CORS_ORIGINS=https://gilloai.com,https://www.gilloai.com

# --- Frontend build (Vite; baked in at docker build time) ---
VITE_API_BASE_URL=https://api.gilloai.com

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=notes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URI form (passwords with !, ^, @, #, etc. must be percent-encoded, or use POSTGRES_* above instead)
POSTGRES_URL=postgres://postgres:change-me-strong-random@postgres:5432/notes

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Auth ---
JWT_SECRET=change-me-min-32-chars-random-hex-or-string  

# --- MinIO (S3-compatible audio storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-random
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-match-root-or-separate-keys
MINIO_BUCKET=audio-notes

# --- Ollama (8GB VPS: prefer 3B or smaller; pull model after deploy) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# --- Whisper ASR ---
WHISPER_URL=http://whisper:9000
ASR_MODEL=base

# --- API (internal worker → HTTP API for health checks only) ---
API_BASE_URL=http://api-server:3000

# --- Optional: Python seed (docker exec … python /app/scripts/seed_initial_data.py) ---
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me
# SEED_ADMIN_DISPLAY_NAME=Admin
# SEED_BUCKETS=General,Work,Personal

# --- Node ---
NODE_ENV=production
