# Global environment template for local and production (Dokploy secrets)

NODE_ENV=development

# Domains
APP_DOMAIN=https://gilloai.com
API_DOMAIN=https://api.gilloai.com
VITE_API_BASE_URL=/api
API_BASE_URL=http://api-server:3000
NGINX_PORT=80

# API
PORT=3000
CORS_ORIGIN=http://localhost
JWT_SECRET=replace-with-strong-secret

# Database
POSTGRES_DB=notes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgres://postgres:postgres@postgres:5432/notes

# Queue/cache
REDIS_URL=redis://redis:6379
QUEUE_CONCURRENCY=1
QUEUE_ATTEMPTS=3
QUEUE_NAMES=process_note

# AI services (8GB-friendly defaults)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
WHISPER_URL=http://whisper:9000
ASR_MODEL=base

# MinIO / object storage
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=audio-notes
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password

# BullMQ dashboard
BULLMQ_DASHBOARD_PORT=3010
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace-with-dashboard-password
