generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  passwordHash String         @map("password_hash")
  displayName  String?        @map("display_name")
  createdAt     DateTime       @default(now()) @map("created_at")

  buckets        Bucket[]
  notes          Note[]
  aiInteractions AiInteraction[]

  @@map("users")
}

model Bucket {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  // Migration sets buckets.fields as NOT NULL DEFAULT '[]'
  fields    Json     @default("[]") @db.JsonB

  notes         Note[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiInteractions AiInteraction[]

  @@index([userId], map: "idx_buckets_user_id")
  @@map("buckets")
}

model Note {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  bucketId      String    @map("bucket_id") @db.Uuid

  originalText  String    @map("original_text")
  structuredJson Json?    @map("structured_json") @db.JsonB

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  // Audio-related columns (added via later migrations)
  category       String?   @map("category")
  audioUrl       String?   @map("audio_url")
  archiveUrl     String?   @map("archive_url")
  durationSeconds Float?   @map("duration_seconds")
  waveformJson   Json?     @map("waveform_json") @db.JsonB

  archived       Boolean   @default(false)

  bucket         Bucket    @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiInteractions AiInteraction[]

  @@index([userId, bucketId, createdAt], map: "idx_notes_user_bucket_created_at")
  @@index([userId, bucketId, archived, createdAt], map: "idx_notes_user_bucket_archived_created_at")

  @@map("notes")
}

model AiInteraction {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  bucketId        String   @map("bucket_id") @db.Uuid

  inputText       String   @map("input_text")
  llmOutput       Json?    @map("llm_output") @db.JsonB
  correctedOutput Json?    @map("corrected_output") @db.JsonB
  correctedByUser Boolean  @default(false) @map("corrected_by_user")
  createdAt       DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bucket Bucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@index([userId, bucketId, createdAt], map: "idx_ai_interactions_user_bucket_created_at")
  @@map("ai_interactions")
}

